{
  "name": "A-Stock-Promotion",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "containerEnv": {
    "PYTHONPATH": "/workspaces/A-Stock-Promotion/src",
    "HOST": "0.0.0.0",
    "PORT": "8080"
  },
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "A-Stock-Promotion Web UI",
      "onAutoForward": "openPreview"
    }
  },
  "postCreateCommand": "python -m unittest discover -s tests",
  "postAttachCommand": {
    "server": "python -m a_stock_promotion.api"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  }
}
